package biedaalt;

public class Student {

    private String ner;
    private String ovog;
    private int nas;
    private String mergejil;
    private double onoo;

    public Student() {
        this.ner = "Unknown";
        this.ovog = "Unknown";
        this.nas = 0;
        this.mergejil = "None";
        this.onoo = 0.0;
    }

    public Student(String n, String o, int age, String m, double s) {
        this.ner = n;
        this.ovog = o;
        this.nas = age;
        this.mergejil = m;
        this.onoo = s;
    }

    private String vnelgeeTootsoh() {
        if (onoo >= 90) {
            return "Mash sain (A)";
        } else if (onoo >= 80) {
            return "Sain (B)";
        } else if (onoo >= 70) {
            return "Dund (C)";
        } else if (onoo >= 60) {
            return "Hangalttai (D)";
        } else {
            return "Muu (F)";
        }
    }

    public static void surguuliinMedeelel() {
        System.out.println("SHUTIS - Medeelel Texnologiin Angi");
    }

    public void medeelelHaruulah() {
        System.out.println("Oyutnii ovog ner: " + ovog + " " + ner);
        System.out.println("Nas: " + nas);
        System.out.println("Surj bui mergejil: " + mergejil);
        System.out.println("Semestriin onoo: " + onoo);
        System.out.println("Vnelgee: " + vnelgeeTootsoh());
    }

    public static void main(String[] args) {
        Student.surguuliinMedeelel();
        System.out.println();

        Student s1 = new Student("Umnud", "Bat", 18, "IT", 88.5);
        Student s2 = new Student("Hoid", "Bat", 19, "Software", 92.0);
        Student s3 = new Student("Urd", "Bat", 20, "Network", 55.0);

        s1.medeelelHaruulah();
        s2.medeelelHaruulah();
        s3.medeelelHaruulah();
    }
}
